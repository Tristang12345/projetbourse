{
  "$schema": "../node_modules/@tauri-apps/cli/schema.json",
  "build": {
    "beforeDevCommand":   "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devPath":            "http://localhost:1420",
    "distDir":            "../dist",
    "withGlobalTauri":    true
  },
  "package": {
    "productName": "Bloomberg Terminal",
    "version":     "1.0.0"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "shell": { "all": false, "open": true },
      "http": {
        "all":   true,
        "scope": ["https://*.finnhub.io/**", "https://*.polygon.io/**", "https://*.alphavantage.co/**"]
      }
    },
    "bundle": {
      "active":      true,
      "icon":        ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.icns", "icons/icon.ico"],
      "identifier":  "com.bloomberg.terminal",
      "targets":     "all"
    },
    "security": {
      "csp": null
    },
    "updater": { "active": false },
    "windows": [
      {
        "fullscreen":  false,
        "resizable":   true,
        "title":       "Bloomberg Terminal",
        "width":       1400,
        "height":      900,
        "minWidth":    1100,
        "minHeight":   700,
        "decorations": true
      }
    ]
  }
}
