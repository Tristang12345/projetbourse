{
  "$schema": "../node_modules/@tauri-apps/cli/schema.json",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devPath": "http://localhost:1420",
    "distDir": "../dist",
    "withGlobalTauri": true
  },
  "package": {
    "productName": "Bloomberg Terminal Pro",
    "version": "1.0.0"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "shell": {
        "all": false,
        "open": true
      },
      "notification": {
        "all": true
      },
      "dialog": {
        "all": true
      },
      "fs": {
        "all": true,
        "scope": ["$DESKTOP/**", "$APPDATA/**"]
      },
      "path": {
        "all": true
      },
      "http": {
        "all": false,
        "request": true,
        "scope": [
          "https://finnhub.io/**",
          "https://ws.finnhub.io/**",
          "https://api.polygon.io/**",
          "https://www.alphavantage.co/**",
          "https://query1.finance.yahoo.com/**",
          "https://query2.finance.yahoo.com/**",
          "https://api.coingecko.com/**",
          "https://fonts.googleapis.com/**",
          "https://fonts.gstatic.com/**"
        ]
      }
    },
    "bundle": {
      "active": true,
      "identifier": "com.bloomberg-terminal.pro",
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ],
      "copyright": "\u00a9 2024 Bloomberg Terminal Pro",
      "category": "Finance",
      "targets": "all",
      "macOS": {
        "frameworks": [],
        "minimumSystemVersion": "10.13"
      },
      "windows": {
        "certificateThumbprint": null,
        "digestAlgorithm": "sha256"
      },
      "deb": {
        "depends": []
      },
      "appimage": {
        "bundleMediaFramework": false
      }
    },
    "security": {
      "csp": "default-src 'self'; connect-src 'self' https://finnhub.io https://ws.finnhub.io wss://ws.finnhub.io https://api.polygon.io https://www.alphavantage.co https://query1.finance.yahoo.com https://query2.finance.yahoo.com https://api.coingecko.com https://fonts.googleapis.com https://fonts.gstatic.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://fonts.gstatic.com; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' data:; script-src 'self' 'unsafe-inline'"
    },
    "updater": {
      "active": false,
      "dialog": true
    },
    "windows": [
      {
        "label": "main",
        "title": "Bloomberg Terminal Pro",
        "width": 1440,
        "height": 900,
        "minWidth": 1100,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "center": true,
        "skipTaskbar": false,
        "fileDropEnabled": false
      }
    ]
  }
}
