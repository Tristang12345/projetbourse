{
  "$schema": "../node_modules/@tauri-apps/cli/schema.json",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devPath": "http://localhost:1420",
    "distDir": "../dist"
  },
  "package": { "productName": "terminal", "version": "0.1.0" },
  "tauri": {
    "allowlist": {
      "all": false,
      "shell": { "all": false, "open": true },
      "http": { "all": true, "scope": ["https://*"] },
      "path": { "all": true },
      "fs": { "all": false, "readFile": true, "writeFile": true, "createDir": true, "scope": ["$APPDATA/terminal/*"] }
    },
    "bundle": {
      "active": true,
      "category": "Finance",
      "copyright": "",
      "deb": { "depends": [] },
      "externalBin": [],
      "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.icns", "icons/icon.ico"],
      "identifier": "com.terminal.app",
      "longDescription": "Bloomberg-like financial terminal with portfolio tracking, news, screener and macro data.",
      "macOS": { "entitlements": null, "exceptionDomain": "", "frameworks": [], "providerShortName": null, "signingIdentity": null },
      "resources": [],
      "shortDescription": "Financial Terminal",
      "targets": "all",
      "windows": { "certificateThumbprint": null, "digestAlgorithm": "sha256", "timestampUrl": "" }
    },
    "security": { "csp": null },
    "updater": { "active": false },
    "windows": [
      {
        "fullscreen": false,
        "height": 900,
        "resizable": true,
        "title": "Terminal",
        "width": 1440,
        "minWidth": 1200,
        "minHeight": 700,
        "decorations": true,
        "transparent": false
      }
    ]
  }
}
