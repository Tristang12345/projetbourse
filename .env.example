# Bloomberg Terminal — API Keys Configuration
# Copy to .env.local and fill in your keys

# Finnhub (free tier: 60 req/min)
# Register at https://finnhub.io/register
VITE_FINNHUB_KEY=your_finnhub_api_key_here

# Polygon.io (free tier: 5 req/min, 15-min delayed data)
# Register at https://polygon.io/dashboard/signup
VITE_POLYGON_KEY=your_polygon_api_key_here

# Alpha Vantage (free tier: 5 req/min, 500 req/day)
# Register at https://www.alphavantage.co/support/#api-key
VITE_ALPHAVANTAGE_KEY=your_alphavantage_api_key_here
